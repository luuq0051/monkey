# Monkey AI - Environment Variables Template
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000

# API Configuration
# Get your API key from Cherry Studio / Minimax dashboard
API=your-api-key-here

# API Endpoint URL
# Example: https://api.minimax.chat or https://cherry-studio-api.com
API_URL=https://your-api-endpoint.com

# Environment (development, production, staging)
NODE_ENV=development

# Additional (optional)
# DEBUG=* # Uncomment for debug mode
